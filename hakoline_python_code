def is_valid_first_move(x, y, player):
    x, y = int(x), int(y)
    if player == 0:
        return x == 0 or x == GRID_WIDTH - 1 or y == 0 or y == GRID_HEIGHT - 1
    else:
        edge_condition = (x == 0 or x == GRID_WIDTH - 1 or y == 0 or  y == GRID_HEIGHT - 1)

        if SECOND_PLAYER_RULE == 0:
            edge_plus_one = (x == 1 or x == GRID_WIDTH - 2 or y == 1 or y == GRID_HEIGHT - 2)
            return edge_condition or edge_plus_one
        else:
            center_x = GRID_WIDTH // 2
            center_y = GRID_HEIGHT // 2
            center_condition = (center_x - 1 <= x <= center_x and
                                center_y - 1 <= y <= center_y)
            return edge_condition or center_condition

def is_edge(x, y):
    return x == 0 or x == GRID_WIDTH - 1 or y == 0 or y == GRID_HEIGHT - 1

def is_adjacent_to_filled(x, y):
    x, y = int(x), int(y)
    for dx in [-1, 0, 1]:
        for dy in [-1, 0, 1]:
            if dx == 0 and dy == 0:
                continue
            nx, ny = x + dx, y + dy
            if 0 <= nx < GRID_WIDTH and 0 <= ny < GRID_HEIGHT:
                if grid[ny][nx] != empty:
                    return True
    return False

def is_valid_move(x, y, player, is_first_move):
    x, y = int(x), int(y)
    if x < 0 or x >= GRID_WIDTH or y < 0 or y >= GRID_HEIGHT:
        return False
    if grid[y][x] != empty:
        return False
    if is_first_move:
        return is_valid_first_move(x, y, player)
    else:
        return is_edge(x, y) or is_adjacent_to_filled(x, y)

def get_valid_moves(player):
    valid_moves = []
    for y in range(GRID_HEIGHT):
        for x in range(GRID_WIDTH):
            if is_valid_move(x, y, player, first_move):
                valid_moves.append((x, y))
    return valid_moves

def draw_grid_fill(grid_x, grid_y):
    global player, game_state, first_move, move_history, turn_start_time

    grid_x, grid_y = int(grid_x), int(grid_y)

    print(f"Attempting to fill: ({grid_x}, {grid_y})")
    print(f"First move: {first_move}")
    print(f"Current player: {player}")

    if not is_valid_move(grid_x, grid_y, player, first_move):
        print("Invalid move")
        return False

    current_color = black if player == 0 else white
    grid[grid_y][grid_x] = current_color
    print(f"Cell filled with {'black' if player == 0 else 'white'}")

    move_history.append((grid_x, grid_y, player, first_move))

    if check_win(grid, current_color):
        game_state = GAME_SET
        print("Game set!")
    elif is_game_over(grid):
        game_state = GAME_SET
        print("Game over!")
    else:
        player = 1 - player
        print(f"Next player: {player}")
        turn_start_time = time.time()  # Reset the turn timer

    if first_move and player == 1:
        print("First player's move completed")
    elif first_move and player == 0:
        first_move = False
        print("Second player's move completed, first move ended")

    return True

def undo_move():
    global player, first_move, move_history, grid, turn_start_time
    if move_history:
        last_move = move_history.pop()
        x, y, last_player, was_first_move = last_move
        grid[y][x] = empty
        player = last_player
        first_move = was_first_move
        turn_start_time = time.time()  # Reset the turn timer
        print(f"Move undone: ({x}, {y})")

def reset_grid():
    global grid, player, first_move, move_history, turn_start_time
    grid = [[empty for _ in range(GRID_WIDTH)] for _ in range(GRID_HEIGHT)]
    player = 0
    first_move = True
    move_history = []
    turn_start_time = time.time()  # Initialize the turn timer
    print(f"Grid reset to {GRID_WIDTH}x{GRID_HEIGHT}")

def check_win(grid, color):
    win_length = WIN_LENGTHS[GRID_WIDTH]
    winning_cells = []

    def is_corner(x, y):
        return (x == 0 and y == 0) or (x == 0 and y == GRID_HEIGHT-1) or \
            (x == GRID_WIDTH-1 and y == 0) or (x == GRID_WIDTH-1 and y == GRID_HEIGHT-1)

    def check_line(start_x, start_y, dx, dy):
        count = 0
        line_cells = []
        for i in range(max(GRID_WIDTH, GRID_HEIGHT)):
            x, y = start_x + i*dx, start_y + i*dy
            if 0 <= x < GRID_WIDTH and 0 <= y < GRID_HEIGHT:
                if grid[y][x] == color:
                    count += 1
                    line_cells.append((x, y))
                    if count == win_length:
                        start_x, start_y = x - (win_length-1)*dx, y - (win_length-1)*dy
                        if not (is_corner(start_x, start_y) or is_corner(x, y)):
                            return line_cells
                else:
                    count = 0
                    line_cells = []
            else:
                break
        return []

    directions = [(1, 0), (0, 1), (1, 1), (1, -1)]
    for dx, dy in directions:
        for y in range(GRID_HEIGHT):
            for x in range(GRID_WIDTH):
                winning_cells = check_line(x, y, dx, dy)
                if winning_cells:
                    return winning_cells

    return []

def count_corner_colors(grid):
    corners = [(0, 0), (0, GRID_HEIGHT-1), (GRID_WIDTH-1, 0), (GRID_WIDTH-1, GRID_HEIGHT-1)]
    black_corners = []
    white_corners = []
    for x, y in corners:
        if grid[y][x] == black:
            black_corners.append((x, y))
        elif grid[y][x] == white:
            white_corners.append((x, y))
    return black_corners, white_corners

