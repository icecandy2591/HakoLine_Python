    edge_text = font.render("Edge", True, white)
    center_text = font.render("Center", True, white)

    screen.blit(edge_text, (edge_button.centerx - edge_text.get_width() // 2, edge_button.centery - edge_text.get_height() // 2 ))
    screen.blit(center_text, (center_button.centerx - center_text.get_width() // 2, center_button.centery - center_text.get_height() // 2 ))

    mode_text = font.render("Game Mode:", True, white)
    screen.blit(mode_text, (WIDTH // 2 - mode_text.get_width() // 2, HEIGHT * 2 // 3  - 30))

    normal_mode_button = pygame.Rect(WIDTH // 2 - 150, HEIGHT * 2 // 3 + 20, 140, 40)
    time_attack_button = pygame.Rect(WIDTH // 2 + 10, HEIGHT * 2 // 3 + 20, 140, 40)

    pygame.draw.rect(screen, yellow if GAME_MODE == 0 else light_black, normal_mode_button, border_radius=10)
    pygame.draw.rect(screen, yellow if GAME_MODE == 1 else light_black, time_attack_button, border_radius=10)

    normal_text = font.render("Normal", True, white)
    time_attack_text = font.render("Time Attack", True, white)

    screen.blit(normal_text, (normal_mode_button.centerx - normal_text.get_width() // 2, normal_mode_button.centery - normal_text.get_height() // 2))
    screen.blit(time_attack_text, (time_attack_button.centerx - time_attack_text.get_width() // 2, time_attack_button.centery - time_attack_text.get_height() // 2))

    pygame.draw.rect(screen, light_black, OPTION_MENU_BUTTON, border_radius=10)
    menu_text = font.render("Back to MENU", True, white)
    screen.blit(menu_text, (OPTION_MENU_BUTTON.centerx - menu_text.get_width() // 2, OPTION_MENU_BUTTON.centery - menu_text.get_height() // 2))

    current_size_text = font.render(f"Current Size: {GRID_WIDTH}x{GRID_HEIGHT}", True, white)
    screen.blit(current_size_text, (WIDTH // 2 - current_size_text.get_width() // 2, HEIGHT * 5 // 6 + 20))

def make_random_move():
    valid_moves = get_valid_moves(player)
    if valid_moves:
        x, y = random.choice(valid_moves)
        draw_grid_fill(x, y)

def main():
    global running, clock, redraw, game_state, player, first_move, current_background, turn_start_time

    pygame.init()
    clock = pygame.time.Clock()

    init_images()
    reset_grid()

    running = True
    redraw = True

    while running:
        for event in pygame.event.get():
            if event.type == pygame.QUIT:
                running = False
            elif event.type == pygame.MOUSEBUTTONDOWN:
                if event.button == 1:
                    if game_state == MENU:
                        handle_menu_click(event.pos)
                    elif game_state == PLAYING:
                        handle_playing_click(event.pos)
                    elif game_state == OPTION:
                        handle_option_click(event.pos)
                    elif game_state == GAME_SET:
                        handle_game_set_click(event.pos)
                    redraw = True
            elif event.type == pygame.MOUSEMOTION:
                if game_state == MENU:
                    if update_menu_hover(event.pos):
                        redraw = True
            elif event.type == pygame.KEYDOWN:
                if game_state == MENU:
                    if event.key == pygame.K_1:
                        game_state = PLAYING
                        reset_grid()
                    elif event.key == pygame.K_2:
                        game_state = OPTION
                elif game_state == PLAYING:
                    if event.key == pygame.K_SPACE:
                        game_state = MENU
                    elif event.key == pygame.K_2:
                        game_state = OPTION
                    elif event.key == pygame.K_u:
                        undo_move()
                    elif event.key == pygame.K_b:
                        current_background = random.choice(background_images)
                        redraw = True
                elif game_state == OPTION:
                    if event.key == pygame.K_SPACE:
                        game_state = MENU
                    elif event.key == pygame.K_c:
                        change_grid_size()
                elif game_state == GAME_SET:
                    if event.key == pygame.K_SPACE:
                        game_state = MENU
                        reset_grid()
                    elif event.key == pygame.K_1:
                        game_state = PLAYING
                        reset_grid()
                    elif event.key == pygame.K_2:
                        game_state = OPTION
                        reset_grid()
                redraw = True

        if game_state == PLAYING and GAME_MODE == 1:
            current_time = time.time()
            current_time_limit = TIME_LIMITS[GRID_WIDTH]  # Get the time limit based on the current grid size
            if current_time - turn_start_time >= current_time_limit:
                make_random_move()
                redraw = True

        if redraw:
            if game_state == PLAYING:
                draw_grid()
            elif game_state == MENU:
                draw_menu()
            elif game_state == GAME_SET:
                draw_game_set()
            elif game_state == OPTION:
                draw_option()

            pygame.display.flip()
            redraw = False

        clock.tick(60)

    pygame.quit()

if __name__ == "__main__":
    main()
