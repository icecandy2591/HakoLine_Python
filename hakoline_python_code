def draw_game_set():
    if current_background:
        screen.blit(current_background, (0, 0))
    else:
        screen.fill((200, 200, 200))
    font = pygame.font.Font(None, 72)

    winning_cells = []
    corner_cells = []
    if check_win(grid, black):
        winner = "Black"
        color = black
        winning_cells = check_win(grid, black)
    elif check_win(grid, white):
        winner = "White"
        color = white
        winning_cells = check_win(grid, white)
    else:
        black_corners, white_corners = count_corner_colors(grid)
        if len(black_corners) > len(white_corners):
            winner = "Black"
            color = black
            corner_cells = black_corners
        elif len(white_corners) > len(black_corners):
            winner = "White"
            color = white
            corner_cells = white_corners
        else:
            winner = "Draw"
            color = light_gray

    if winner == "Draw":
        title = font.render("It's a Draw!", True, color)
    else:
        title = font.render(f"{winner} Wins!", True, color)

    screen.blit(title, (WIDTH // 2 - title.get_width() // 2, HEIGHT // 2 - title.get_height() // 2))

    # Draw the grid
    draw_grid()

    # Highlight winning cells or corners
    draw_victory_highlight(screen, winning_cells, corner_cells)

    if winner == "Black":
        screen.blit(left_character_win, (40, HEIGHT // 2 - 100))
    elif winner == "White":
        screen.blit(right_character_win, (WIDTH - 350, HEIGHT // 2 - 150))

    font = pygame.font.Font(None, 36)

    pygame.draw.rect(screen, (200, 200, 200), GAME_SET_MENU_BUTTON)
    menu_text = font.render("Back to MENU", True, black)
    screen.blit(menu_text, (GAME_SET_MENU_BUTTON.centerx - menu_text.get_width() // 2, GAME_SET_MENU_BUTTON.centery - menu_text.get_height() // 2))

    instruction = font.render("Press SPACE or click the button to return to menu", True, white)
