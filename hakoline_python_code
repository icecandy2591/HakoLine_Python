def is_game_over(grid):
    return all(cell != empty for row in grid for cell in row)

def handle_option_click(pos):
    global GRID_SIZE_INDEX, SECOND_PLAYER_RULE, GAME_MODE, game_state
    changed = False
    if GRID_6X6_BUTTON.collidepoint(pos) and GRID_SIZE_INDEX != 0:
        GRID_SIZE_INDEX = 0
        changed = True
    elif GRID_8X8_BUTTON.collidepoint(pos) and GRID_SIZE_INDEX != 1:
        GRID_SIZE_INDEX = 1
        changed = True
    elif GRID_10X10_BUTTON.collidepoint(pos) and GRID_SIZE_INDEX != 2:
        GRID_SIZE_INDEX = 2
        changed = True
    elif OPTION_MENU_BUTTON.collidepoint(pos):
        game_state = MENU
        return True

    edge_button = pygame.Rect(WIDTH // 2 - 150, HEIGHT * 2 // 3 - 90, 140, 40)
    center_button = pygame.Rect(WIDTH // 2 + 10, HEIGHT * 2 // 3 - 90, 140, 40)

    if edge_button.collidepoint(pos) and SECOND_PLAYER_RULE != 0:
        SECOND_PLAYER_RULE = 0
        changed = True
    elif center_button.collidepoint(pos) and SECOND_PLAYER_RULE != 1:
        SECOND_PLAYER_RULE = 1
        changed = True

    normal_mode_button = pygame.Rect(WIDTH // 2 - 150, HEIGHT * 2 // 3 + 20, 140, 40)
    time_attack_button = pygame.Rect(WIDTH // 2 + 10, HEIGHT * 2 // 3 + 20, 140, 40)

    if normal_mode_button.collidepoint(pos) and GAME_MODE != 0:
        GAME_MODE = 0
        changed = True
    elif time_attack_button.collidepoint(pos) and GAME_MODE != 1:
        GAME_MODE = 1
        changed = True

    menu_button = pygame.Rect(WIDTH // 2 - 100, HEIGHT * 3 // 4 + 50, 200, 50)
    if menu_button.collidepoint(pos):
        game_state = MENU
        return True

    if changed:
        update_grid_size()
        reset_grid()

    return changed

