def get_grid(x, y):
    if GRID_START_X <= x < GRID_START_X + GRID_TOTAL_WIDTH and GRID_START_Y <= y < GRID_START_Y + GRID_TOTAL_HEIGHT:
        grid_x = int((x - GRID_START_X) // GRID_SIZE)
        grid_y = int((y - GRID_START_Y) // GRID_SIZE)
        return grid_x, grid_y
    return None

